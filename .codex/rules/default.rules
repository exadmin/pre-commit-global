# .codex/rules/default.rules

prefix_rule(
    pattern = ["git", "init"],
    decision = "allow",
    match = ["git init"],
)

prefix_rule(
    pattern = ["git", "status"],
    decision = "allow",
    match = ["git status"],
)

prefix_rule(
    pattern = ["git", "diff"],
    decision = "allow",
    match = ["git diff"],
)

# Allows any variants of commit
prefix_rule(
    pattern = ["git", "commit"],
    decision = "allow",
    match = ["git commit -m msg", "git commit --amend -m msg"],
)

prefix_rule(
    pattern = ["mkdir"],
    decision = "allow",
    match = ["mkdir a", "mkdir -p a/b"],
)

prefix_rule(
    pattern = ["bash", "-lc"],
    decision = "allow",
    match = ['bash -lc echo'],
)